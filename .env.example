# ─── 必須 ───
# MySQL 接続文字列。本番では未設定だと起動を拒否します（in-memory フォールバックなし）。
DATABASE_URL=mysql://user:pass@localhost:3306/keirisys
# JWT 署名用シークレット（ランダムな64文字以上を推奨）
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
# Cookie 署名用シークレット（ランダムな32文字以上を推奨）
COOKIE_SECRET=CHANGE_ME_RANDOM_32_CHARS

# ─── 管理者初期アカウント（初回起動時のみ seed。空なら seed をスキップ） ───
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_INITIAL_LOGIN
ADMIN_NAME=管理者

# ─── Stripe ───
# 開発は sk_test_... / 本番は sk_live_...。本番 Live Key はこのファイルやリポジトリに絶対に書かない。
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── SMTP（メール送信） ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── 任意 ───
NODE_ENV=development
BASE_PATH=/keiri/
PORT=3100
ALLOWED_ORIGINS=https://sns-tool.online
SITE_URL=https://sns-tool.online/keiri
